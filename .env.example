# Groq API keys — optional, simulation runs without them
# Add up to 4 keys for load balancing across the free tier
GROQ_API_KEY=your_key_here
GROQ_API_KEY2=
GROQ_API_KEY3=
GROQ_API_KEY4=

# Model (optional, defaults to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Log level: info | debug | warn | error | none
LOG_LEVEL=info
