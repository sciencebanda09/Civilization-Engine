# Groq API keys — optional, simulation runs without them
# Add up to 4 keys for load balancing across the free tier
GROQ_API_KEY=your_key_here
GROQ_API_KEY2=
GROQ_API_KEY3=
GROQ_API_KEY4=

# Two-tier model configuration (optional):
# Small model for fast/cheap calls (nano-triage, narration)
# Big model for expensive/smart calls (hypotheses, debate, adjudication)
# If only one is set, it's used for both tiers
GROQ_SMALL_MODEL=llama-3.1-8b-instant
GROQ_BIG_MODEL=llama-3.3-70b-versatile

# Legacy single-model setting (used as fallback for both tiers if GROQ_SMALL/BIG not set)
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local/Colab) — uncomment to use instead of Groq
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_SMALL_MODEL=qwen2.5:7b
# OLLAMA_BIG_MODEL=qwen2.5:14b

# Viewer server port (default 3030)
# VIEWER_PORT=3030

# Log level: info | debug | warn | error | none
LOG_LEVEL=info
